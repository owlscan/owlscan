## PhantomSignal .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
.env
.env.*
!.env.example

# PhantomSignal runtime
phantomsignal.db
phantomsignal.db-shm
phantomsignal.db-wal
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
exports/
*.enc
/data/
instance/

# API keys — NEVER commit these
config/phantomsignal.yaml
config/*.yaml
config/*.json
config/*.toml

# Scrapy
.scrapy/
scrapy.cfg

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.iml

# Claude Code local settings
.claude/

# Docker
.docker/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Playwright
playwright-report/
test-results/

# Certificates
*.pem
*.key
*.crt

# Temp
*.tmp
*.bak
tmp/
temp/

# PhantomSignal scan data / exports
/scans/
/reports/
/screenshots/

# Offline wheel cache (Docker build artifact — regenerate with pip download)
wheels/
